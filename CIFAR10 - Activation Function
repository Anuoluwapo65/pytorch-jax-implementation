      "outputs": [],
      "source": [
        "class ReLU(Activation_name):\n",
        "  def forward(self, x):\n",
        "    return x * (x>0).float()\n",
        "\n",
        "class LeakyReLU(Activation_name):\n",
        "  def __init__(self, alpha = 0.01):\n",
        "    super().__init__()\n",
        "    self.config[\"alpha\"] = alpha\n",
        "\n",
        "  def forward(self, x):\n",
        "    return torch.where(x>0, x, self.config[\"alpha\"] * x)\n",
        "\n",
        "\n",
        "\n",
        "class ELU(Activation_name):\n",
        "  def forward(self, x):\n",
        "    return torch.where(x>0, x, torch.exp(x)-1)\n",
        "\n",
        "class Swish(Activation_name):\n",
        "  def forward(self, x):\n",
        "    return x * torch.sigmoid(x)"
      ]
    },
