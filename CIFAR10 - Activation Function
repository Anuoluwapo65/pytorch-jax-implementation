      "source": [
        "class Sigmoid(Activation_name):\n",
        "  def forward(self,x):\n",
        "    return 1 / (1 + torch.exp(-x))\n",
        "\n",
        "\n",
        "class Tanh(Activation_name):\n",
        "  def forward(self, x):\n",
        "    neg_x, pos_x = torch.exp(-x), torch.exp(x)\n",
        "    return (neg_x - pos_x) / (neg_x + pos_x)"
      ]
    },
    {
