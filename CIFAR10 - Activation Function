        "class NeuralNetwork(nn.Module):\n",
        "  def __init__(self, act_fn, input_size = 3072, num_classes = 12, hidden_size = [784, 512, 256, 256]):\n",
        "    super().__init__()\n",
        "    self.act_fn = act_fn # Store the activation function instance\n",
        "    self.config = {\"act_fn\": act_fn.config,\n",
        "                   \"input_size\": input_size,\n",
        "                   \"num_classes\": num_classes,\n",
        "                   \"hidden_size\": hidden_size}\n",
        "\n",
        "    layers = []\n",
        "    layer_sizes = [input_size] + hidden_size\n",
        "    for layer_index in range(1, len(layer_sizes)):\n",
        "      layers.append(nn.Linear(layer_sizes[layer_index -1], layer_sizes[layer_index]))\n",
        "      layers.append(act_fn)\n",
        "    layers.append(nn.Linear(layer_sizes[-1], num_classes))\n",
        "\n",
        "    self.layers = nn.Sequential(*layers)\n",
        "\n",
        "  def forward(self, x):\n",
        "      x = x.view(x.size(0), -1)\n",
        "      out = self.layers(x)\n",
        "      return out"
      ]
    },
