        "def test_model(net, data_loader):\n",
        "  net.eval()\n",
        "  true_pred, num_pred = 0.,0\n",
        "  for imgs, labels in data_loader:\n",
        "    imgs, labels = imgs.to(device), labels.to(device)\n",
        "    with torch.no_grad():\n",
        "      pred = net(imgs).argmax(dim = -1)\n",
        "      true_pred += (pred == labels).sum().item()\n",
        "      num_pred += labels.shape[0]\n",
        "  test_acc = true_pred / num_pred\n",
        "  return test_acc\n",
        "\n",
        "def train_model(net, model_name, max_epoch = 50, patience = 7, batch_size = 356, overwrite = True):\n",
        "  model_file = __get__model__file(checkpoint_path, model_name)\n",
        "  config_file = __get__config__file(checkpoint_path, model_name)\n",
        "  files_exist = os.path.isfile(model_file) and os.path.isfile(config_file)\n",
        "\n",
        "  # Scenario 1: Model exists and we don't want to overwrite. Just load and test.\n",
        "  if files_exist and not overwrite:\n",
        "    print(f\"Model {model_name} exists and overwrite is False. Loading pre-trained model.\")\n",
        "    load_model(model_name, checkpoint_path, net=net)\n",
        "    test_acc = test_model(net, test_loader)\n",
        "    print(f\"Test Accuracy (pre-loaded): {test_acc * 100.0:4.2f}%\")\n",
        "    return test_acc\n",
        "\n",
        "  # Scenario 2: Model does not exist OR overwrite is True. Proceed with training.\n",
        "  if files_exist and overwrite:\n",
        "    print(f\"Model {model_name} exists but overwrite is True. Training and overwriting.\")\n",
        "  elif not files_exist:\n",
        "    print(f\"Model {model_name} does not exist. Training a new model.\")\n",
        "\n",
        "  optimizer = torch.optim.SGD(net.parameters(), lr = 1e-4, momentum =0.0)\n",
        "  loss_module = nn.CrossEntropyLoss()\n",
        "  train_loader = data.DataLoader(train_set, shuffle = True, batch_size = 256, num_workers = 2, drop_last = False, pin_memory = True)\n",
        "  val_loader = data.DataLoader(val_set, shuffle = False, batch_size = 256, drop_last = False)\n",
        "\n",
        "  val_scores = []\n",
        "  best_val_acc = -1\n",
        "  epochs_since_last_improvement = 0\n",
        "\n",
        "  for epoch in range(max_epoch):\n",
        "    net.train()\n",
        "    true_pred, num_pred = 0.,0\n",
        "    for imgs, labels in train_loader:\n",
        "      imgs, labels = imgs.to(device), labels.to(device)\n",
        "      pred = net(imgs)\n",
        "      loss = loss_module(pred,labels)\n",
        "      optimizer.zero_grad()\n",
        "      loss.backward()\n",
        "      optimizer.step()\n",
        "      true_pred += (pred.argmax(dim = -1)== labels).sum().item()\n",
        "      num_pred += labels.shape[0]\n",
        "    acc = true_pred / num_pred\n",
        "\n",
        "    val_acc = test_model(net, val_loader)\n",
        "    val_scores.append(val_acc)\n",
        "    print(f\"[Epoch {epoch+1:2d}] Training accuracy {acc*100.0:05.2f}%, validation accuracy {val_acc*100.0:05.2f}%\")\n",
        "\n",
        "    if val_acc > best_val_acc:\n",
        "      best_val_acc = val_acc\n",
        "      epochs_since_last_improvement = 0\n",
        "      print(\"Best performing model so far! Saving it.\")\n",
        "      save_model(net, model_name, checkpoint_path) # Save the model and config\n",
        "    else:\n",
        "      epochs_since_last_improvement += 1\n",
        "      if epochs_since_last_improvement >= patience:\n",
        "        print(f\"Early stoppage due to no improvement in {patience} epochs.\")\n",
        "        break # Stop training early\n",
        "\n",
        "  plt.plot([i for i in range(1, len(val_scores)+ 1)], val_scores)\n",
        "  plt.xlabel(\"Epoch\")\n",
        "  plt.ylabel(\"Validation Accuracy\")\n",
        "  plt.title(f\"Validation performance of the {model_name}\")\n",
        "  plt.show()\n",
        "  plt.close()\n",
        "\n",
        "  # After training, load the best saved model for final testing.\n",
        "  # This is always done if training occurred.\n",
        "  print(f\"Loading best model for {model_name} for final test.\")\n",
        "  load_model(model_name, checkpoint_path, net=net)\n",
        "\n",
        "  test_acc = test_model(net, test_loader)\n",
        "  print(f\"Final Test Accuracy for {model_name}: {test_acc *100.0:4.2f}%\")\n",
        "  return test_acc"
      ]
