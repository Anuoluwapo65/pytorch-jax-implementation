        "def visualizing_activations(net, color = \"C0\"):\n",
        "  activations = {}\n",
        "\n",
        "  net.eval()\n",
        "  small_loader = data.DataLoader(train_set, shuffle = True, batch_size = 256)\n",
        "  imgs, label = next(iter(small_loader))\n",
        "  imgs, label = imgs.to(device), label.to(device)\n",
        "  imgs = imgs.view(imgs.size(0), -1)\n",
        "  with torch.no_grad():\n",
        "       for layer_index, layer in enumerate(net.layers[:-1]):\n",
        "           imgs = layer(imgs)\n",
        "           activations[layer_index] = imgs.view(-1).cpu().numpy()\n",
        "\n",
        "\n",
        "  columns = 4\n",
        "  rows = math.ceil(len(activations)/columns)\n",
        "  fig, ax = plt.subplots(rows, columns, figsize = (columns*3.5, rows*3.5))\n",
        "  fig_index = 0\n",
        "  for key in activations:\n",
        "      row_idx = fig_index // columns\n",
        "      col_idx = fig_index % columns\n",
        "      # Handle cases where ax is 1D (single row/column) or 2D\n",
        "      if rows == 1 and columns == 1:\n",
        "          key_ax = ax\n",
        "      elif rows == 1 or columns == 1:\n",
        "          key_ax = ax[fig_index]\n",
        "      else:\n",
        "          key_ax = ax[row_idx, col_idx]\n",
        "\n",
        "      sns.histplot(data = activations[key], bins = 50, stat = \"density\", kde = True, ax = key_ax, color = color)\n",
        "      key_ax.set_title(f\"Layer {key}\") # Set title for each subplot\n",
        "      if net.config[\"act_fn\"][\"name\"]:\n",
        "          print(f\"Activations distribution in the CIFAR10 {net.config[\"act_fn\"][\"name\"]}\")\n",
        "      fig_index += 1\n",
        "  fig.suptitle(f\"Activations distribution in the CIFAR10 {net.config[\"act_fn\"][\"name\"]}\", fontsize = 15, y = 1.05) # Add a main title for the figure\n",
        "  plt.subplots_adjust(hspace = 0.9, wspace = 0.4)\n",
        "  plt.show()\n",
        "  plt.close()"
      ]
