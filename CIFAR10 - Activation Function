        "def __get__model__file(model_path, model_name):\n",
        "  return os.path.join(model_path, model_name + \".tar\")\n",
        "\n",
        "def __get__config__file(model_path, model_name):\n",
        "  return os.path.join(model_path, model_name + \".config\")\n",
        "\n",
        "\n",
        "def load_model(model_name, model_path, net = None):\n",
        "  config_file, model_file = __get__config__file(model_path, model_name), __get__model__file(model_path,model_name)\n",
        "  assert os.path.isfile(config_file), f\"config_file {config_file} does not exist\"\n",
        "  assert os.path.isfile(model_file), f\"model_file {model_file} does not exist\"\n",
        "\n",
        "  with open(config_file, \"r\") as f:\n",
        "    config_dict = json.load(f)\n",
        "\n",
        "  if net is None:\n",
        "    act_fn_nm = config_dict[\"act_fn\"].pop(\"name\") # Removed .lower()\n",
        "    act_fn = act_names[act_fn_nm](**config_dict.pop(\"act_fn\"))\n",
        "    net = NeuralNetwork(act_fn = act_fn, **config_dict)\n",
        "    net.load_state_dict(torch.load(model_file, map_location = device))\n",
        "    return net\n",
        "\n",
        "\n",
        "def save_model(model, model_name, model_path):\n",
        "  os.makedirs(model_path, exist_ok = True)\n",
        "  config_dict = model.config\n",
        "  config_file, model_file = __get__config__file(model_path, model_name), __get__model__file(model_path, model_name)\n",
        "  with open(config_file, \"w\") as f:\n",
        "    json.dump(config_dict, f)\n",
        "  torch.save(model.state_dict(), model_file)"
      ]
    },
